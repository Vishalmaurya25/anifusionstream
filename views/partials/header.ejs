<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Watch your favorite anime series online. Explore by genre, seasons, and episodes.">
    <title>AniFusionstream</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #111827; } /* bg-gray-900 */
.logo-gradient {
        /* Move gradient styles here */
        background: linear-gradient(to right, #ec4899, #a855f7);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        display: inline-block;
        transition: all 0.3s ease;
    }

    .logo-gradient:hover {
        /* Use brightness or scale instead of opacity */
        filter: brightness(1.2);
        transform: scale(1.02);
    }
        /* Premium Glass Effect keeping bg-gray-800 colors */
        .glass-nav {
            background-color: rgba(31, 41, 55, 0.9); /* Gray-800 with transparency */
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
        }

        .nav-link {
            font-size: 0.85rem;
            font-weight: 600;
            color: #d1d5db; /* gray-300 */
            text-transform: uppercase;
            letter-spacing: 0.05em;
            transition: all 0.3s ease;
            position: relative;
        }

        .nav-link:hover {
            color: #ffffff;
        }

        /* Animated underline effect */
        .nav-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: -4px;
            left: 0;
            background: linear-gradient(to right, #ec4899, #a855f7); /* Pink to Purple */
            transition: width 0.3s ease;
        }

        .nav-link:hover::after {
            width: 100%;
        }

        /* Mobile Menu Drawer Animation */
        #mobile-menu {
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            background-color: #1f2937; /* bg-gray-800 */
        }

        .mobile-link {
            font-size: 1.25rem;
            font-weight: 700;
            padding: 1rem 2rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        }

        /* Hamburger Animation */
        .btn-active .line-1 { transform: translateY(8px) rotate(45deg); }
        .btn-active .line-2 { opacity: 0; }
        .btn-active .line-3 { transform: translateY(-8px) rotate(-45deg); }
    </style>
</head>
<body class="bg-gray-900 text-white pt-20">

    <nav class="glass-nav px-6 py-4">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            
            <div class="text-3xl font-black tracking-tighter">
    <a href="/" class="logo-gradient">AniFusionstream</a>
</div>

            <div class="hidden md:flex items-center space-x-8">
                <a href="/" class="nav-link">Home</a>
                <a href="/dmca" class="nav-link">DMCA</a>
                <a href="/privacy-policy" class="nav-link">Privacy</a>
                <a href="/contact-us" class="nav-link">Contact</a>
                
                <div class="h-6 w-px bg-gray-700 mx-2"></div>

                <% if (!session.isUserAuthenticated) { %>
                    <a href="/user/login" class="nav-link">Login</a>
                    <a href="/user/register" class="bg-gradient-to-r from-pink-600 to-purple-600 px-5 py-2 rounded-lg text-xs font-bold uppercase tracking-widest hover:scale-105 transition-transform">Register</a>
                <% } else { %>
                    <a href="/user/logout" class="nav-link text-red-400 hover:text-red-300">Logout</a>
                <% } %>
            </div>

            <button id="hamburger-btn" class="md:hidden flex flex-col gap-1.5 z-[1100]">
                <span class="line-1 w-7 h-0.5 bg-white transition-all duration-300"></span>
                <span class="line-2 w-7 h-0.5 bg-white transition-all duration-300"></span>
                <span class="line-3 w-7 h-0.5 bg-white transition-all duration-300"></span>
            </button>
        </div>
    </nav>

    <div id="mobile-menu" class="fixed inset-0 translate-x-full z-[1050] md:hidden pt-24">
        <div class="flex flex-col h-full">
            <a href="/" class="mobile-link text-white">Home</a>
            <a href="/dmca" class="mobile-link text-gray-300">DMCA</a>
            <a href="/privacy-policy" class="mobile-link text-gray-300">Privacy Policy</a>
            <a href="/contact-us" class="mobile-link text-gray-300">Contact Us</a>
            
            <div class="mt-auto p-8 space-y-4">
                <% if (!session.isUserAuthenticated) { %>
                    <a href="/user/login" class="block text-center py-4 bg-gray-700 rounded-xl font-bold uppercase tracking-widest">Login</a>
                    <a href="/user/register" class="block text-center py-4 bg-gradient-to-r from-pink-600 to-purple-600 rounded-xl font-bold uppercase tracking-widest">Register</a>
                <% } else { %>
                    <a href="/user/logout" class="block text-center py-4 bg-red-600/20 text-red-400 border border-red-600/30 rounded-xl font-bold uppercase tracking-widest">Logout Account</a>
                <% } %>
            </div>
        </div>
    </div>

    <script>
        const btn = document.getElementById('hamburger-btn');
        const menu = document.getElementById('mobile-menu');

        btn.addEventListener('click', () => {
            const isOpen = !menu.classList.contains('translate-x-full');
            if (isOpen) {
                menu.classList.add('translate-x-full');
                btn.classList.remove('btn-active');
                document.body.style.overflow = 'auto';
            } else {
                menu.classList.remove('translate-x-full');
                btn.classList.add('btn-active');
                document.body.style.overflow = 'hidden';
            }
        });

        // Auto-close menu on link click
        document.querySelectorAll('.mobile-link').forEach(link => {
            link.addEventListener('click', () => {
                menu.classList.add('translate-x-full');
                btn.classList.remove('btn-active');
                document.body.style.overflow = 'auto';
            });
        });
    </script>
</body>
</html>