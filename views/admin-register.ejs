<%- include('partials/header') %>

<style>
    :root {
        --bg-deep: #0b0e11;
        --card-navy: #151b23;
        --input-dark: #1c232d;
        --primary-blue: #3b82f6;
        --text-muted: #9ca3af;
    }

    body { 
        background-color: var(--bg-deep); 
        color: #ffffff; 
        font-family: 'Inter', sans-serif; 
    }

    .auth-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 85vh;
        padding: 3rem 1.25rem;
    }

    .ui-card {
        background-color: var(--card-navy);
        border: 1px solid rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(25px);
        border-radius: 2.5rem;
        width: 100%;
        max-width: 480px;
        padding: 4rem 2.5rem;
        box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.7);
    }

    .ui-label {
        font-size: 0.75rem;
        font-weight: 800;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin-bottom: 0.7rem;
        display: block;
    }

    .ui-input {
        background-color: var(--input-dark);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 1rem;
        color: #ffffff;
        padding: 1.1rem;
        padding-right: 3.5rem; /* Space for the eye icon */
        width: 100%;
        transition: all 0.3s ease;
        font-size: 0.95rem;
    }

    .ui-input:focus {
        outline: none;
        border-color: var(--primary-blue);
        box-shadow: 0 0 0 1px var(--primary-blue);
        background-color: #232a33;
    }

    .ui-button {
        background-color: var(--primary-blue);
        color: #ffffff;
        font-weight: 900;
        padding: 1.2rem;
        border-radius: 1.25rem;
        width: 100%;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        text-transform: uppercase;
        letter-spacing: 0.2em;
        border: none;
        margin-top: 1.5rem;
        cursor: pointer;
    }

    .ui-button:hover {
        transform: translateY(-3px);
        filter: brightness(1.1);
        box-shadow: 0 15px 30px rgba(59, 130, 246, 0.4);
    }

    .field-group { 
        position: relative; 
        width: 100%;
    }

    /* Position the eye button inside the input */
    .toggle-btn {
        position: absolute;
        right: 1.2rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        background: none;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: color 0.2s;
        z-index: 10;
    }

    .toggle-btn:hover { color: #fff; }

    .help-text {
        font-size: 10px;
        color: #64748b;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-top: 8px;
        display: block;
    }
</style>

<div class="auth-wrapper">
    <div class="text-center mb-10">
        <h1 class="text-4xl md:text-5xl font-black tracking-tighter uppercase">
            Admin <span class="text-blue-500">Signup</span>
        </h1>
        <p class="text-gray-500 mt-2 font-medium">Create a new system administrator account</p>
    </div>

    <div class="ui-card">
        <% if (typeof messages !== 'undefined' && messages.error) { %>
            <div class="bg-red-500/10 border border-red-500/30 text-red-400 p-4 rounded-2xl mb-8 text-xs font-black text-center uppercase tracking-widest">
                <%= messages.error %>
            </div>
        <% } %>

        <form action="/admin/register" method="POST">
            <div class="mb-4">
                <label class="ui-label">Administrator ID</label>
                <input type="text" name="username" class="ui-input" placeholder="Username" required>
            </div>

            <div class="mb-4">
                <label class="ui-label">Access Password</label>
                <div class="field-group">
                    <input type="password" name="password" id="password" class="ui-input" placeholder="••••••••" required>
                    <button type="button" class="toggle-btn" onclick="toggleField('password', 'eye-pw')">
                        <svg id="eye-pw" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                    </button>
                </div>
            </div>

            <div class="mb-4">
                <label class="ui-label">Confirm Password</label>
                <div class="field-group">
                    <input type="password" name="confirmPassword" id="confirmPassword" class="ui-input" placeholder="••••••••" required>
                    <button type="button" class="toggle-btn" onclick="toggleField('confirmPassword', 'eye-cpw')">
                        <svg id="eye-cpw" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                    </button>
                </div>
            </div>

            <div class="mb-8">
                <label class="ui-label">Master Admin Code</label>
                <input type="text" name="adminCode" class="ui-input" placeholder="SECRET_CODE_FROM_ENV" required>
                <span class="help-text italic text-red-500">REQUIRED FOR AUTHORIZATION</span>
            </div>

            <button type="submit" class="ui-button">Register Admin</button>
            <div class="mt-6 text-center">
                <a href="/admin/login" class="text-gray-500 text-xs font-bold hover:text-white transition-colors">BACK TO LOGIN</a>
            </div>
        </form>
    </div>
</div>

<script>
    /**
     * Unified Toggle Function
     * @param {string} inputId - ID of the password input
     * @param {string} iconId - ID of the SVG eye icon
     */
    function toggleField(inputId, iconId) {
        const passwordInput = document.getElementById(inputId);
        const eyeIcon = document.getElementById(iconId);
        const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
        
        passwordInput.setAttribute('type', type);

        if (type === 'text') {
            // Show Eye Slashed (Hidden state)
            eyeIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />`;
        } else {
            // Show Eye Open (Visible state)
            eyeIcon.innerHTML = `
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            `;
        }
    }
</script>

<%- include('partials/footer') %>