<%- include('partials/header') %>

<style>
    :root {
        --bg-deep: #0b0e11;
        --card-navy: #151b23;
        --input-dark: #1c232d;
        --primary-blue: #3b82f6;
        --text-muted: #9ca3af;
    }

    body { 
        background-color: var(--bg-deep); 
        color: #ffffff; 
        font-family: 'Inter', sans-serif; 
    }

    .auth-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 85vh;
        padding: 3rem 1.25rem;
    }

    .ui-card {
        background-color: var(--card-navy);
        border: 1px solid rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(20px);
        border-radius: 2.5rem;
        width: 100%;
        max-width: 450px;
        padding: 4rem 2.5rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
    }

    .ui-label {
        font-size: 0.75rem;
        font-weight: 800;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.6rem;
        display: block;
    }

    .ui-input {
        background-color: var(--input-dark);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 1rem;
        color: #ffffff;
        padding: 1.1rem;
        width: 100%;
        transition: all 0.3s ease;
        font-size: 0.95rem;
    }

    .ui-input:focus {
        outline: none;
        border-color: var(--primary-blue);
        box-shadow: 0 0 0 1px var(--primary-blue);
        background-color: #232a33;
    }

    .ui-button {
        background-color: var(--primary-blue);
        color: #ffffff;
        font-weight: 800;
        padding: 1.1rem;
        border-radius: 1rem;
        width: 100%;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border: none;
        margin-top: 1.5rem;
        cursor: pointer;
    }

    .ui-button:hover {
        transform: translateY(-2px);
        filter: brightness(1.1);
        box-shadow: 0 10px 25px rgba(59, 130, 246, 0.3);
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--text-muted);
        font-size: 0.85rem;
        font-weight: 700;
        margin-bottom: 2rem;
        transition: color 0.2s;
    }

    .back-btn:hover {
        color: #fff;
    }
</style>

<div class="auth-wrapper">
    <div class="text-center mb-10">
        <div class="flex justify-center mb-4">
            <div class="p-4 bg-blue-500/10 rounded-full border border-blue-500/20">
                <svg class="w-8 h-8 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
            </div>
        </div>
        <h1 class="text-4xl font-black tracking-tighter uppercase">
            Account <span class="text-blue-500">Recovery</span>
        </h1>
        <p class="text-gray-500 mt-2 font-medium">Verify your email to reset your password</p>
    </div>

    <div class="ui-card">
        <a href="/user/login" class="back-btn">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Login
        </a>

        <% if (typeof messages !== 'undefined' && messages.length > 0) { %>
            <div class="bg-red-500/10 border border-red-500/20 text-red-400 p-4 rounded-xl mb-8 text-xs font-bold text-center uppercase tracking-widest">
                <%= messages %>
            </div>
        <% } %>

        <form action="/user/forgot-password" method="POST">
            <div class="mb-8">
                <label class="ui-label">Registered Email</label>
                <input type="email" name="email" class="ui-input" placeholder="Enter your email" required>
                <p class="text-[10px] text-gray-600 mt-3 font-bold uppercase tracking-wider italic">
                    Note: We will send a 6-digit OTP to this address.
                </p>
            </div>

            <button type="submit" class="ui-button">
                Send OTP
            </button>
        </form>
    </div>
</div>

<%- include('partials/footer') %>