<%- include('partials/header') %>

<style>
    :root {
        --bg-deep: #0b0e11;
        --card-navy: #151b23;
        --input-dark: #1c232d;
        --primary-blue: #3b82f6;
        --text-muted: #9ca3af;
    }

    body { 
        background-color: var(--bg-deep); 
        color: #ffffff; 
        font-family: 'Inter', sans-serif; 
    }

    /* Standardized Auth Centering */
    .auth-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 85vh;
        padding: 3rem 1.25rem;
    }

    .ui-card {
        background-color: var(--card-navy);
        border: 1px solid rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(25px);
        border-radius: 2.5rem;
        width: 100%;
        max-width: 450px;
        padding: 4rem 2.5rem;
        box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.7);
    }

    .ui-label {
        font-size: 0.75rem;
        font-weight: 800;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin-bottom: 0.7rem;
        display: block;
    }

    .ui-input {
        background-color: var(--input-dark);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 1rem;
        color: #ffffff;
        padding: 1.1rem;
        width: 100%;
        transition: all 0.3s ease;
        font-size: 0.95rem;
    }

    .ui-input:focus {
        outline: none;
        border-color: var(--primary-blue);
        box-shadow: 0 0 0 1px var(--primary-blue);
        background-color: #232a33;
    }

    .ui-button {
        background-color: var(--primary-blue);
        color: #ffffff;
        font-weight: 900;
        padding: 1.2rem;
        border-radius: 1.25rem;
        width: 100%;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        text-transform: uppercase;
        letter-spacing: 0.2em;
        border: none;
        margin-top: 1.5rem;
        cursor: pointer;
    }

    .ui-button:hover {
        transform: translateY(-3px);
        filter: brightness(1.1);
        box-shadow: 0 15px 30px rgba(59, 130, 246, 0.4);
    }

    .security-badge {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        padding: 4px 12px;
        border-radius: 99px;
        font-size: 10px;
        font-weight: 900;
        letter-spacing: 2px;
        text-transform: uppercase;
        border: 1px solid rgba(239, 68, 68, 0.2);
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--text-muted);
        font-size: 0.85rem;
        font-weight: 700;
        margin-bottom: 2rem;
        transition: color 0.2s;
    }

    .back-btn:hover { color: #fff; }

    .help-text {
        font-size: 10px;
        color: #64748b;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-top: 8px;
        display: block;
    }
</style>

<div class="auth-wrapper">
    <div class="text-center mb-10">
        <div class="mb-4"><span class="security-badge">Identity Verification</span></div>
        <h1 class="text-4xl font-black tracking-tighter uppercase">
            Admin <span class="text-blue-500">Recovery</span>
        </h1>
        <p class="text-gray-500 mt-2 font-medium">Verify your credentials to proceed</p>
    </div>

    <div class="ui-card">
        <a href="/admin/login" class="back-btn">← Back to Portal</a>

        <% if (typeof messages !== 'undefined' && messages.error) { %>
            <div class="bg-red-500/10 border border-red-500/30 text-red-400 p-4 rounded-2xl mb-8 text-xs font-black text-center uppercase tracking-widest">
                <%= messages.error %>
            </div>
        <% } %>

        <form action="/admin/forgot-password" method="POST">
            <div class="mb-6">
                <label class="ui-label">Administrator ID</label>
                <input type="text" name="username" class="ui-input" placeholder="Enter Username" required>
            </div>

            <div class="mb-10">
                <label class="ui-label">Master Admin Code</label>
                <input type="text" name="adminCode" class="ui-input" placeholder="Secret Key Required" required>
                <span class="help-text">Input your system security key</span>
            </div>

            <button type="submit" class="ui-button">Verify & Proceed</button>
        </form>
    </div>
</div>

<%- include('partials/footer') %>