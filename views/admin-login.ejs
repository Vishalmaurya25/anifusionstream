<%- include('partials/header') %>

<style>
    :root {
        --bg-deep: #0b0e11;
        --card-navy: #151b23;
        --input-dark: #1c232d;
        --primary-blue: #3b82f6;
        --text-muted: #9ca3af;
    }

    body { 
        background-color: var(--bg-deep); 
        color: #ffffff; 
        font-family: 'Inter', sans-serif; 
    }

    /* Standardized Auth Centering */
    .auth-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 85vh;
        padding: 2rem 1.25rem;
    }

    .ui-card {
        background-color: var(--card-navy);
        border: 1px solid rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(25px);
        border-radius: 2.5rem;
        width: 100%;
        max-width: 450px;
        padding: 4rem 2.5rem;
        box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.7);
    }

    .ui-label {
        font-size: 0.75rem;
        font-weight: 800;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin-bottom: 0.7rem;
        display: block;
    }

    .ui-input {
        background-color: var(--input-dark);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 1rem;
        color: #ffffff;
        padding: 1.1rem;
        width: 100%;
        transition: all 0.3s ease;
        font-size: 0.95rem;
        font-weight: 500;
    }

    .ui-input:focus {
        outline: none;
        border-color: var(--primary-blue);
        box-shadow: 0 0 0 1px var(--primary-blue);
        background-color: #232a33;
    }

    .ui-button {
        background-color: var(--primary-blue);
        color: #ffffff;
        font-weight: 900;
        padding: 1.2rem;
        border-radius: 1.25rem;
        width: 100%;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        text-transform: uppercase;
        letter-spacing: 0.2em;
        border: none;
        margin-top: 1rem;
        cursor: pointer;
    }

    .ui-button:hover {
        transform: translateY(-3px);
        filter: brightness(1.1);
        box-shadow: 0 15px 30px rgba(59, 130, 246, 0.4);
    }

    .admin-badge {
        background: rgba(59, 130, 246, 0.1);
        color: var(--primary-blue);
        padding: 4px 12px;
        border-radius: 99px;
        font-size: 10px;
        font-weight: 900;
        letter-spacing: 2px;
        text-transform: uppercase;
        border: 1px solid rgba(59, 130, 246, 0.2);
    }

    /* Password Toggle Alignment */
    .field-group { position: relative; }

    .toggle-btn {
        position: absolute;
        right: 1.2rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        transition: color 0.2s;
        background: none;
        border: none;
        cursor: pointer;
    }

    .toggle-btn:hover { color: #fff; }

    .secondary-link {
        color: var(--text-muted);
        font-size: 0.8rem;
        font-weight: 700;
        transition: color 0.2s;
    }

    .secondary-link:hover { color: #fff; text-decoration: underline; }
</style>

<div class="auth-wrapper">
    <div class="text-center mb-10">
        <div class="mb-4">
            <span class="admin-badge">Secure Console</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-black tracking-tighter uppercase">
            Admin <span class="text-blue-500">Portal</span>
        </h1>
        <p class="text-gray-500 mt-2 font-medium">Restricted Access • AniFusionStream Core</p>
    </div>

    <div class="ui-card">
        <% if (typeof messages !== 'undefined' && messages.length > 0) { %>
            <div class="bg-red-500/10 border border-red-500/30 text-red-400 p-4 rounded-2xl mb-8 text-xs font-black text-center uppercase tracking-widest">
                <i class="fas fa-exclamation-triangle mr-2"></i> <%= messages %>
            </div>
        <% } %>

        <form action="/admin/login" method="POST">
            <div class="mb-6">
                <label class="ui-label">Administrator ID</label>
                <input type="text" name="username" class="ui-input" placeholder="Username" required>
            </div>

            <div class="mb-10">
                <label class="ui-label">Access Key</label>
                <div class="field-group">
                    <input type="password" name="password" id="password" class="ui-input" placeholder="••••••••" required>
                    <button type="button" id="toggle-password" class="toggle-btn">
                        <svg id="eye-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                        </svg>
                    </button>
                </div>
            </div>

            <button type="submit" class="ui-button">
                Authorize Login
            </button>

            <div class="mt-10 flex flex-col items-center gap-3">
                <a href="/admin/forgot-password" class="secondary-link">Reset Admin Key?</a>
                <a href="/admin/register" class="text-[10px] text-blue-500/60 font-black uppercase tracking-widest hover:text-blue-400">System Registration</a>
            </div>
        </form>
    </div>
</div>

<script>
    const togglePassword = document.getElementById('toggle-password');
    const passwordInput = document.getElementById('password');
    const eyeIcon = document.getElementById('eye-icon');

    togglePassword.addEventListener('click', () => {
        const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
        passwordInput.setAttribute('type', type);

        if (type === 'text') {
            eyeIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />`;
        } else {
            eyeIcon.innerHTML = `
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            `;
        }
    });
</script>

<%- include('partials/footer') %>