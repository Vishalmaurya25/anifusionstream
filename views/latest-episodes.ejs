<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Latest Episodes | AniFusionstream</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-accent: #ff3e3e; /* Premium Red */
            --bg-dark: #0f1014;
            --card-bg: #1a1c23;
            --text-main: #ffffff;
            --text-dim: #a0a0a0;
            --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .header-section {
            margin-bottom: 40px;
            text-align: center;
        }

        .header-section h1 {
            font-size: 2.5rem;
            font-weight: 800;
            letter-spacing: -1px;
            margin-bottom: 10px;
        }

        .header-section .underline {
            width: 60px;
            height: 4px;
            background: var(--primary-accent);
            margin: 0 auto;
            border-radius: 2px;
        }

        /* STRICT 3x3 GRID SYSTEM */
        .episodes-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr); /* Exactly 3 horizontal */
            grid-template-rows: repeat(3, auto);   /* Exactly 3 vertical */
            gap: 25px;
            padding: 10px;
        }

        /* EPISODE CARD DESIGN */
        .episode-card {
            background: var(--card-bg);
            border-radius: 16px;
            overflow: hidden;
            position: relative;
            text-decoration: none;
            color: inherit;
            transition: var(--transition);
            border: 1px solid rgba(255, 255, 255, 0.05);
            display: flex;
            flex-direction: column;
            aspect-ratio: 16 / 10; /* Maintains consistent vertical height */
        }

        .episode-card:hover {
            transform: translateY(-8px);
            border-color: var(--primary-accent);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.5), 0 0 15px rgba(255, 62, 62, 0.2);
        }

        /* Card Content Inner */
        .card-image-area {
            position: relative;
            flex-grow: 1;
            background: linear-gradient(45deg, #1a1c23, #252833);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        /* Play Overlay Effect */
        .card-image-area::after {
            content: '▶';
            position: absolute;
            font-size: 2rem;
            color: white;
            opacity: 0;
            transition: var(--transition);
            background: rgba(255, 62, 62, 0.8);
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
        }

        .episode-card:hover .card-image-area::after {
            opacity: 1;
        }

        /* Season/Episode Badge */
        .badge {
            position: absolute;
            top: 15px;
            left: 15px;
            background: var(--primary-accent);
            color: white;
            padding: 5px 12px;
            border-radius: 8px;
            font-size: 0.75rem;
            font-weight: 700;
            z-index: 2;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        }

        .card-details {
            padding: 15px;
            background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
            position: absolute;
            bottom: 0;
            width: 100%;
            box-sizing: border-box;
        }

        .anime-title {
            font-size: 1.1rem;
            font-weight: 700;
            margin: 0 0 5px 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            display: block;
        }

        .ep-title {
            font-size: 0.85rem;
            color: var(--text-dim);
            margin: 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* RESPONSIVE BEHAVIOR */
        @media (max-width: 992px) {
            .episodes-grid {
                grid-template-columns: repeat(2, 1fr); /* 2 per row on tablets */
            }
        }

        @media (max-width: 600px) {
            .episodes-grid {
                grid-template-columns: 1fr; /* 1 per row on mobile */
            }
            .header-section h1 {
                font-size: 1.8rem;
            }
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="header-section">
            <h1>LATEST RELEASES</h1>
            <div class="underline"></div>
        </div>

        <div class="episodes-grid">
            <% if (latestEpisodes && latestEpisodes.length > 0) { %>
                <% latestEpisodes.forEach(episode => { %>
                    <a href="/anime/<%= episode.animeId %>" class="episode-card">
                        <div class="badge">
                            S<%= episode.seasonNumber %> - EP <%= episode.episodeNumber %>
                        </div>

                        <div class="card-image-area">
                             <span style="opacity: 0.1; font-weight: 800; font-size: 3rem;">ANIFUSION</span>
                        </div>

                        <div class="card-details">
                            <span class="anime-title"><%= episode.animeTitle %></span>
                            <p class="ep-title"><%= episode.title || 'No Episode Title' %></p>
                        </div>
                    </a>
                <% }); %>
            <% } else { %>
                <div style="grid-column: span 3; text-align: center; padding: 50px;">
                    <p style="color: var(--text-dim);">No episodes found.</p>
                </div>
            <% } %>
        </div>
    </div>

</body>
</html>