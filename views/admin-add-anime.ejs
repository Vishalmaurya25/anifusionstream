<%- include('partials/header') %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Anime | AniFusionStream</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-deep: #0b0e11;
            --card-navy: #151b23;
            --input-dark: #1c232d;
            --primary-blue: #3b82f6;
            --text-muted: #9ca3af;
        }

        body { 
            background-color: var(--bg-deep); 
            color: #ffffff; 
            font-family: 'Inter', sans-serif; 
        }

        /* Full page centering */
        .admin-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 90vh;
            width: 100%;
            padding: 2rem 1.25rem;
        }

        .ui-card {
            background-color: var(--card-navy);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 2rem;
            width: 100%;
            max-width: 600px;
            padding: 3rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .ui-label {
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.75rem;
            display: block;
        }

        .ui-input {
            background-color: var(--input-dark);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 0.85rem;
            color: #ffffff;
            padding: 1.1rem;
            width: 100%;
            transition: all 0.2s ease;
        }

        .ui-input:focus {
            outline: none;
            border-color: var(--primary-blue);
            box-shadow: 0 0 0 1px var(--primary-blue);
        }

        /* Genre Checkbox List */
        .genre-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 10px;
            background: rgba(0,0,0,0.2);
            padding: 1.25rem;
            border-radius: 1rem;
            border: 1px solid rgba(255,255,255,0.02);
        }

        .genre-item {
            display: flex;
            align-items: center;
            font-size: 0.85rem;
            color: var(--text-muted);
            cursor: pointer;
            transition: color 0.2s;
        }

        .genre-item:hover { color: #fff; }

        input[type="checkbox"] {
            margin-right: 8px;
            accent-color: var(--primary-blue);
            width: 16px;
            height: 16px;
        }

        .ui-button {
            background-color: var(--primary-blue);
            color: #ffffff;
            font-weight: 700;
            padding: 1.1rem;
            border-radius: 0.85rem;
            width: 100%;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .ui-button:hover {
            transform: translateY(-2px);
            filter: brightness(1.1);
            box-shadow: 0 10px 20px rgba(59, 130, 246, 0.3);
        }

        @media (max-width: 640px) {
            .ui-card { padding: 2rem 1.5rem; }
            .genre-grid { grid-template-columns: repeat(2, 1fr); }
        }
    </style>
</head>
<body>

    <div class="admin-wrapper">
        
        <div class="text-center mb-10">
            <a href="/admin/dashboard" class="text-blue-500 text-xs font-bold mb-4 inline-block hover:underline">← BACK TO DASHBOARD</a>
            <h1 class="text-4xl md:text-5xl font-black tracking-tight">
                Add New <span class="text-blue-500">Anime</span>
            </h1>
        </div>

        <div class="ui-card">
            <form action="/admin/add-anime" method="POST">
                
                <div class="mb-8">
                    <label class="ui-label">Anime Name</label>
                    <input type="text" name="name" class="ui-input" placeholder="e.g. Solo Leveling" required>
                </div>

                <div class="mb-8">
                    <label class="ui-label">Poster Image URL</label>
                    <input type="text" name="imageUrl" class="ui-input" placeholder="https://image-link.com/poster.jpg" required>
                </div>

                <div class="mb-8">
                    <label class="ui-label">Description</label>
                    <textarea name="description" rows="4" class="ui-input" placeholder="Write a brief synopsis..." required></textarea>
                </div>

                <div class="mb-10">
                    <label class="ui-label">Select Genres</label>
                    <div class="genre-grid">
                        <% genres.forEach(genre => { %>
                            <label class="genre-item">
                                <input type="checkbox" name="genres" value="<%= genre._id %>">
                                <%= genre.name %>
                            </label>
                        <% }) %>
                    </div>
                </div>

                <button type="submit" class="ui-button">
                    Publish to Catalog
                </button>
            </form>
        </div>
    </div>

</body>
</html>
<%- include('partials/footer') %>