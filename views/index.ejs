<%- include('partials/header') %>

<div class="container mx-auto px-4 md:px-8">
    
    <div class="mt-8 mb-6 flex justify-center relative">
        <form action="/search" method="GET" id="search-form" class="w-full max-w-3xl">
            <div class="glass-search flex items-center px-4 py-2 shadow-2xl transition-all">
                
                <input type="text" name="q" id="search-input" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" 
                    placeholder="Search anime..." 
                    class="bg-transparent text-white text-sm w-full py-2 px-2 focus:outline-none" 
                    autocomplete="off">
                
                <button type="submit" class="mx-2 p-2 rounded-full hover:bg-white/10 text-blue-400 transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke-width="2.5"></path>
                    </svg>
                </button>

                <div class="h-6 w-px bg-white/10 mx-2"></div>

                <select name="genre" id="genre-select" class="bg-transparent text-gray-400 text-xs font-bold focus:outline-none cursor-pointer hover:text-white transition-colors">
                    <option value="">Genres</option>
                    <% genres.forEach(genre => { %>
                        <option value="<%= genre._id %>" <%= typeof selectedGenre !== 'undefined' && selectedGenre === genre._id.toString() ? 'selected' : '' %>>
                            <%= genre.name %>
                        </option>
                    <% }) %>
                </select>
            </div>

            <div id="suggestions" class="absolute z-[100] w-full max-w-lg left-1/2 -translate-x-1/2 bg-[#1c232d]/95 backdrop-blur-xl rounded-2xl mt-2 overflow-hidden shadow-2xl border border-white/10 hidden animate-suggestion-drop"></div>
        </form>
    </div>

    <% if (typeof isSearchResult !== 'undefined' && isSearchResult) { %>
        <div class="mb-12 glass-panel p-6 rounded-3xl">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-black text-white uppercase tracking-tighter">
                    <span class="text-blue-500">Results:</span> <%= animes.length %> Found
                </h2>
                <a href="/" class="text-[10px] font-black bg-red-600/20 text-red-500 border border-red-500/30 px-4 py-2 rounded-full hover:bg-red-600 hover:text-white transition-all">
                    CLEAR SEARCH X
                </a>
            </div>
            
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
                <% animes.forEach(anime => { %>
                    <div class="anime-card-glass rounded-2xl p-2 transition-all">
                        <a href="/anime/<%= anime._id %>">
                            <img src="<%= anime.imageUrl %>" alt="<%= anime.name %>" class="w-full h-48 md:h-64 object-cover rounded-xl shadow-lg">
                            <p class="text-center mt-3 text-white font-bold text-xs md:text-sm truncate px-2"><%= anime.name %></p>
                        </a>
                    </div>
                <% }) %>
            </div>
        </div>
    <% } %>

    <%- include('animation') %>

    <section class="mt-12 mb-12">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-1.5 h-8 bg-blue-600 rounded-full"></div>
            <h2 class="text-2xl font-black text-white tracking-tight">Latest Episodes</h2>
        </div>

        <div class="grid grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2 md:gap-4">
            <% (latestEpisodes || []).slice(0, 13).forEach(function(episode) { %>
                <div class="episode-glass-card group cursor-pointer p-1.5 md:p-2 rounded-xl border border-white/5 transition-all">
                    <a href="/anime/<%= episode.anime ? episode.anime._id : '' %>" class="block">
                        <div class="relative aspect-video overflow-hidden rounded-lg">
                            <img src="<%= episode.anime && episode.anime.imageUrl ? episode.anime.imageUrl : '/images/default.png' %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                            <div class="absolute top-1 left-1 bg-black/80 backdrop-blur-md text-[8px] font-black text-white px-1.5 py-0.5 rounded border border-white/10 uppercase">
                                S<%= episode.seasonNumber %> E<%= episode.episodeNumber %>
                            </div>
                        </div>
                        <div class="mt-2 text-center">
                            <h3 class="text-white text-[9px] md:text-xs font-bold truncate"><%= episode.anime ? episode.anime.name : 'Unknown' %></h3>
                            <p class="text-gray-500 text-[8px] uppercase font-black tracking-tighter">ep <%= episode.episodeNumber %></p>
                        </div>
                    </a>
                </div>
            <% }) %>
        </div>
    </section>

    <% if (typeof isSearchResult === 'undefined' || !isSearchResult) { %>
        <% genres.forEach(genre => { 
            const genreAnimes = animes.filter(anime => anime.genres.some(g => g._id.toString() === genre._id.toString()));
            if(genreAnimes.length > 0) { %>
            <div class="mb-12">
                <div class="flex justify-between items-center mb-6">
                    <div class="flex items-center gap-3">
                        <div class="text-blue-500 font-black text-xl">#</div>
                        <h2 class="text-xl font-black text-white tracking-tight capitalize"><%= genre.name %></h2>
                    </div>
                    <a href="/search?genre=<%= genre._id %>" class="text-gray-500 text-[10px] font-black uppercase tracking-widest hover:text-white transition-colors">View All →</a>
                </div>

                <div class="anime-scroll flex gap-5 overflow-x-auto pb-6 snap-x">
                    <% genreAnimes.forEach(anime => { %>
                        <div class="anime-card-glass flex-shrink-0 w-32 md:w-48 snap-center">
                            <a href="/anime/<%= anime._id %>" class="group">
                                <div class="relative rounded-2xl overflow-hidden border border-white/5 shadow-2xl">
                                    <img src="<%= anime.imageUrl %>" class="w-full h-44 md:h-64 object-cover group-hover:scale-105 transition-transform duration-700">
                                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                                </div>
                                <p class="mt-3 text-white text-xs md:text-sm font-bold text-center truncate group-hover:text-blue-400"><%= anime.name %></p>
                            </a>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } }) %>
    <% } %>

    <div class="mt-20 mb-10 flex justify-center px-4">
        <div class="w-full max-w-xl bg-gradient-to-br from-[#151b23] to-[#0b0e11] border border-white/5 rounded-[2.5rem] p-10 md:p-14 text-center shadow-2xl relative overflow-hidden group">
            <h2 class="text-3xl font-black text-white mb-4">Need to reach <span class="text-blue-500">us?</span></h2>
            <p class="text-gray-400 text-sm md:text-base leading-relaxed mb-8">
                Send a message directly to the admin team and we'll get back to you as soon as possible.
            </p>
            <a href="/contact-us" class="inline-flex items-center justify-center gap-3 bg-blue-600 hover:bg-blue-500 text-white font-black py-4 px-12 rounded-2xl transition-all shadow-xl shadow-blue-600/20 hover:-translate-y-1">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 8l7 8.941L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                CONTACT ADMIN
            </a>
        </div>
    </div>
</div>

<%- include('popular') %>
<%- include('partials/footer') %>

<script type="application/json" id="animes-data">
    <%- JSON.stringify(animes.map(anime => ({ name: anime.name, id: anime._id }))) %>
</script>

<script>
    const animes = JSON.parse(document.getElementById('animes-data').textContent);
    const searchInput = document.getElementById('search-input');
    const suggestionsDiv = document.getElementById('suggestions');
    const genreSelect = document.getElementById('genre-select');

    searchInput.addEventListener('input', () => {
        const query = searchInput.value.trim().toLowerCase();
        suggestionsDiv.innerHTML = '';
        suggestionsDiv.classList.add('hidden');
        if (query.length === 0) return;
        const filtered = animes.filter(a => a.name.toLowerCase().includes(query)).slice(0, 10);
        if (filtered.length === 0) return;
        filtered.forEach(a => {
            const div = document.createElement('div');
            div.className = 'p-3 hover:bg-white/10 cursor-pointer text-white text-sm font-medium transition-all';
            div.textContent = a.name;
            div.onclick = () => {
                searchInput.value = a.name;
                suggestionsDiv.classList.add('hidden');
                document.getElementById('search-form').submit();
            };
            suggestionsDiv.appendChild(div);
        });
        suggestionsDiv.classList.remove('hidden');
    });

    genreSelect.onchange = () => { if (genreSelect.value) { searchInput.value = ''; document.getElementById('search-form').submit(); } };
    document.onclick = (e) => { if (!searchInput.contains(e.target) && !suggestionsDiv.contains(e.target)) { suggestionsDiv.classList.add('hidden'); } };
</script>

<style>
    body { background-color: #0b0e11; color: #fff; }
    .glass-search { background: rgba(21, 27, 35, 0.6); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 99px; }
    .anime-card-glass { background: rgba(21, 27, 35, 0.4); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); border: 1px solid rgba(255, 255, 255, 0.05); }
    .episode-glass-card { background: rgba(255, 255, 255, 0.02); backdrop-filter: blur(4px); }
    .anime-scroll { -ms-overflow-style: none; scrollbar-width: none; }
    .anime-scroll::-webkit-scrollbar { display: none; }
    @keyframes suggestionDrop { 0% { opacity: 0; transform: translate(-50%, -10px); } 100% { opacity: 1; transform: translate(-50%, 0); } }
    .animate-suggestion-drop { animation: suggestionDrop 0.25s ease-out forwards; }
   
    /* ... your existing styles ... */

    /* THE FIX: Style the Dropdown and its Options */
    #genre-select {
        background-color: transparent;
        color: #9ca3af; /* Muted gray text */
    }

    /* Target the actual list that pops out */
    #genre-select option {
        background-color: #1c232d; /* Matches Search Suggestion background */
        color: #ffffff;            /* White text */
        padding: 10px;
    }

    /* Remove the default blue highlight in some browsers and use your theme */
    #genre-select:focus {
        outline: none;
    }

    /* Optional: Style the select hover state */
    #genre-select:hover {
        color: #ffffff;
    }

</style>