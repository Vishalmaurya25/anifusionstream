<%- include('partials/header') %>

<style>
    :root {
        --bg-deep: #0b0e11;
        --card-navy: #151b23;
        --input-dark: #1c232d;
        --primary-blue: #3b82f6;
        --text-muted: #9ca3af;
    }

    body { 
        background-color: var(--bg-deep); 
        color: #ffffff; 
        font-family: 'Inter', sans-serif; 
    }

    /* Standardized Centering Wrapper */
    .auth-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 85vh;
        padding: 3rem 1.25rem;
    }

    .ui-card {
        background-color: var(--card-navy);
        border: 1px solid rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(20px);
        border-radius: 2.5rem;
        width: 100%;
        max-width: 480px;
        padding: 4rem 2.5rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
    }

    .ui-label {
        font-size: 0.75rem;
        font-weight: 800;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.6rem;
        display: block;
    }

    .ui-input {
        background-color: var(--input-dark);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 1rem;
        color: #ffffff;
        padding: 1.1rem;
        width: 100%;
        transition: all 0.3s ease;
        font-size: 0.95rem;
    }

    .ui-input:focus {
        outline: none;
        border-color: var(--primary-blue);
        box-shadow: 0 0 0 1px var(--primary-blue);
        background-color: #232a33;
    }

    .ui-button {
        background-color: var(--primary-blue);
        color: #ffffff;
        font-weight: 800;
        padding: 1.1rem;
        border-radius: 1rem;
        width: 100%;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border: none;
        margin-top: 1.5rem;
        cursor: pointer;
    }

    .ui-button:hover {
        transform: translateY(-2px);
        filter: brightness(1.1);
        box-shadow: 0 10px 25px rgba(59, 130, 246, 0.3);
    }

    /* Password Toggle Integration */
    .password-container {
        position: relative;
    }

    .toggle-btn {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        transition: color 0.2s;
        background: none;
        border: none;
        cursor: pointer;
    }

    .toggle-btn:hover { color: #fff; }

    .help-text {
        font-size: 0.7rem;
        color: #64748b;
        margin-top: 0.5rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
</style>

<div class="auth-wrapper">
    <div class="text-center mb-10">
        <div class="flex justify-center mb-4">
            <div class="p-4 bg-blue-500/10 rounded-full border border-blue-500/20">
                <svg class="w-8 h-8 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.14A15.023 15.023 0 0112 3.472a15.022 15.022 0 013.083 1.242m4.244 3.441A15.037 15.037 0 0121 12c0 1.268-.156 2.498-.448 3.669m-1.493 3.903A15.054 15.054 0 0112 21a15.05 15.05 0 01-8.125-2.347m0 0L3 21m0 0l2.143-3.125m9.932-11.536L13 13m4 4L13 13m-2-2L9 9" />
                </svg>
            </div>
        </div>
        <h1 class="text-4xl font-black tracking-tighter uppercase">
            Reset <span class="text-blue-500">Security</span>
        </h1>
        <p class="text-gray-500 mt-2 font-medium">Finalize your new access credentials</p>
    </div>

    <div class="ui-card">
        <% if (typeof messages !== 'undefined' && messages.error && messages.error.length > 0) { %>
            <div class="bg-red-500/10 border border-red-500/20 text-red-400 p-4 rounded-xl mb-8 text-xs font-bold">
                <% messages.error.forEach(message => { %>
                    <p class="text-center uppercase tracking-widest"><%= message %></p>
                <% }) %>
            </div>
        <% } %>

        <form action="/user/reset-password" method="POST">
            <div class="mb-6">
                <label class="ui-label">Confirm OTP</label>
                <input type="text" name="otp" class="ui-input" placeholder="Enter 6-digit code" required>
                <p class="help-text">Verify your code one last time</p>
            </div>

            <div class="mb-8">
                <label class="ui-label">New Secure Password</label>
                <div class="password-container">
                    <input type="password" name="newPassword" id="password" class="ui-input" placeholder="••••••••" required>
                    <button type="button" id="toggle-password" class="toggle-btn">
                        <svg id="eye-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                        </svg>
                    </button>
                </div>
                <p class="help-text">Use a mix of letters, numbers & symbols</p>
            </div>

            <button type="submit" class="ui-button">
                Update Password
            </button>
        </form>
    </div>
</div>

<script>
    const togglePassword = document.getElementById('toggle-password');
    const passwordInput = document.getElementById('password');
    const eyeIcon = document.getElementById('eye-icon');

    togglePassword.addEventListener('click', () => {
        const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
        passwordInput.setAttribute('type', type);

        if (type === 'text') {
            eyeIcon.innerHTML = `
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
            `;
        } else {
            eyeIcon.innerHTML = `
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            `;
        }
    });
</script>

<%- include('partials/footer') %>