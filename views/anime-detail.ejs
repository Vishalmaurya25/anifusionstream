<%- include('partials/header') %>

<style>
    :root {
        --bg-deep: #0b0e11;
        --card-navy: #151b23;
        --accent-blue: #3b82f6;
        --accent-yellow: #facc15;
        --glass-border: rgba(255, 255, 255, 0.05);
    }

    body { 
        background-color: var(--bg-deep); 
        font-family: 'Inter', sans-serif;
        color: #f3f4f6;
    }

    /* Glass Effect Hero Card */
    .glass-card {
        background: rgba(21, 27, 35, 0.6);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--glass-border);
        border-radius: 1.5rem;
    }

    /* --- MODERN EPISODE CARD STYLING --- */
    .episode-card {
        background: var(--card-navy);
        border: 1px solid var(--glass-border);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border-radius: 1.25rem;
        overflow: hidden;
        position: relative;
    }

    .episode-card:hover {
        transform: translateY(-8px);
        border-color: var(--accent-blue);
        box-shadow: 0 20px 40px -15px rgba(59, 130, 246, 0.5);
    }

    .ep-image-container {
        position: relative;
        aspect-ratio: 16/9;
        overflow: hidden;
    }

    .ep-image-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
        filter: brightness(0.8);
    }

    .episode-card:hover .ep-image-container img {
        transform: scale(1.1);
        filter: brightness(1);
    }

    /* Play Button Overlay */
    .play-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.3);
        opacity: 0;
        transition: all 0.4s ease;
    }

    .episode-card:hover .play-overlay {
        opacity: 1;
    }

    .play-icon-circle {
        width: 45px;
        height: 45px;
        background: var(--accent-blue);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 20px var(--accent-blue);
        transform: scale(0.5);
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .episode-card:hover .play-icon-circle {
        transform: scale(1);
    }

    .ep-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(4px);
        padding: 4px 10px;
        border-radius: 8px;
        font-size: 10px;
        font-weight: 900;
        color: var(--accent-yellow);
        z-index: 10;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .player-shadow {
        box-shadow: 0 0 80px -20px rgba(59, 130, 246, 0.2);
    }
   /* --- MODERN CINEMATIC INFO BOX --- */
.admin-info-banner {
    position: relative;
    background: rgba(15, 23, 42, 0.6); /* Deep navy glass */
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-left: 4px solid var(--accent-blue); /* Strong accent line */
    border-radius: 1.25rem;
    padding: 1.75rem 2rem;
    margin-top: 3rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    box-shadow: 0 20px 50px -15px rgba(0, 0, 0, 0.5);
}

/* Background Glow Effect */
.admin-info-banner::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.05) 0%, transparent 70%);
    pointer-events: none;
}

/* Floating Badge */
.info-badge {
    background: var(--accent-blue);
    color: white;
    font-size: 9px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 4px 12px;
    border-radius: 99px;
    margin-bottom: 0.75rem;
    box-shadow: 0 4px 15px rgba(59, 130, 246, 0.4);
}

.admin-info-banner h3 {
    color: #ffffff;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-size: 1.1rem;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 10px;
}

.admin-info-banner h3 i {
    color: var(--accent-blue);
    filter: drop-shadow(0 0 5px var(--accent-blue));
}

.admin-info-banner p {
    color: #9ca3af; /* Muted gray for elegance */
    font-weight: 500;
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    max-width: 80%;
}

/* --- PREMIUM SUPPORT & SHARE BOX --- */
.support-share-card {
    background: linear-gradient(135deg, rgba(21, 27, 35, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%);
    backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 1.5rem;
    padding: 2.5rem 1.5rem;
    margin-top: 2rem;
    text-align: center;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
}

.support-share-card h2 {
    color: var(--accent-yellow);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
}

.support-share-card p {
    color: #d1d5db;
    font-size: 0.95rem;
    max-width: 500px;
    margin: 0 auto 2rem auto;
    line-height: 1.6;
}

/* Social Icon Grid */
.share-grid {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
}

.share-btn {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    color: white;
    font-size: 1.2rem;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
}

.share-btn:hover {
    transform: translateY(-5px) scale(1.1);
    box-shadow: 0 10px 20px rgba(0,0,0,0.3);
}

/* Brand Colors on Hover */
.btn-fb:hover { background: #1877F2; border-color: #1877F2; }
.btn-wa:hover { background: #25D366; border-color: #25D366; }
.btn-x:hover { background: #000000; border-color: #ffffff; }
.btn-tg:hover { background: #0088cc; border-color: #0088cc; }
.btn-copy:hover { background: var(--accent-blue); border-color: var(--accent-blue); }

/* Animation for attention */
.pulse-glow {
    animation: pulseGlow 3s infinite ease-in-out;
}

@keyframes pulseGlow {
    0%, 100% { border-color: rgba(59, 130, 246, 0.2); }
    50% { border-color: rgba(59, 130, 246, 0.5); }
}
    /* Custom scrollbar */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: var(--bg-deep); }
    ::-webkit-scrollbar-thumb { background: #374151; border-radius: 10px; }
</style>

<div class="container mx-auto px-4 py-8 max-w-6xl">

    <div class="glass-card mb-10 p-6 md:p-8 flex flex-col md:flex-row gap-8 items-center">
        <div class="relative group">
            <img src="<%= anime.imageUrl %>" alt="<%= anime.name %>" 
                 class="w-full md:w-64 rounded-xl shadow-2xl object-cover transition-transform duration-500 hover:scale-105">
        </div>

        <div class="flex-1 space-y-4">
            <h1 class="text-3xl md:text-5xl font-black tracking-tighter uppercase leading-tight">
                <% const nameParts = anime.name.split(' '); %>
                <span class="text-white"><%= nameParts[0] %></span>
                <span class="text-yellow-400"><%= nameParts.slice(1).join(' ') %></span>
            </h1>

            <div class="flex flex-wrap gap-3 text-[10px] font-bold uppercase tracking-widest text-gray-400">
                <span class="bg-white/5 px-3 py-1.5 rounded-full border border-white/5">📅 <%= anime.year || '2024' %></span>
                <span class="bg-white/5 px-3 py-1.5 rounded-full border border-white/5">🕒 <%= anime.duration || '24m' %></span>
                <span class="bg-blue-500/10 text-blue-400 px-3 py-1.5 rounded-full border border-blue-500/20">HD Dual Audio</span>
            </div>

            <p class="text-gray-300 leading-relaxed font-medium text-base md:text-lg border-l-2 border-blue-500 pl-4">
                <%= anime.description %>
            </p>
        </div>
    </div>

    <div id="video-area" class="mb-12 hidden">
        <div class="glass-card p-2 player-shadow overflow-hidden">
            <div id="player-container" class="relative w-full aspect-video bg-black rounded-lg overflow-hidden"></div>
        </div>
        <div class="mt-4 flex justify-between items-center">
            <h2 id="active-video-title" class="text-xl font-black text-white uppercase tracking-tight"></h2>
            <button onclick="document.getElementById('video-area').classList.add('hidden')" class="text-xs font-bold text-gray-500 hover:text-white uppercase tracking-widest">Close Player ×</button>
        </div>
    </div>

    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <h2 class="text-2xl font-black uppercase tracking-tighter flex items-center gap-3">
            <div class="w-1.5 h-6 bg-blue-500 rounded-full"></div>
            Episode <span class="text-gray-500">Library</span>
        </h2>
        
        <select id="season-select" class="appearance-none bg-gray-800 border border-white/10 text-white px-6 py-2 rounded-xl font-bold text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 min-w-[160px]">
            <% anime.seasons.forEach((season, index) => { %>
                <option value="<%= index %>">Season <%= season.seasonNumber %></option>
            <% }) %>
        </select>
    </div>

    <div id="episodes-container">
        <% anime.seasons.forEach((season, seasonIndex) => { %>
            <div class="season-section grid grid-cols-3 gap-4 md:gap-6 <%= seasonIndex === 0 ? '' : 'hidden' %>" data-season="<%= seasonIndex %>">
                <% season.episodes.forEach(episode => { %>
                    <div class="episode-card cursor-pointer group"
                         data-video-url="<%= episode.videoUrl %>"
                         data-embed-code="<%= episode.embedCode || '' %>"
                         data-title="Ep <%= episode.episodeNumber %>: <%= episode.title %>">
                        
                        <div class="ep-image-container">
                            <div class="ep-badge">EPISODE <%= episode.episodeNumber %></div>
                            <img src="<%= anime.imageUrl %>" alt="<%= episode.title %>">
                            
                            <div class="play-overlay">
                                <div class="play-icon-circle">
                                    <i class="fas fa-play text-white text-xs"></i>
                                </div>
                            </div>
                        </div>

                        <div class="p-3">
                            <h4 class="font-bold text-[10px] md:text-xs text-gray-400 uppercase tracking-widest mb-1">Chapter <%= episode.episodeNumber %></h4>
                            <h4 class="font-black text-[11px] md:text-sm text-white group-hover:text-blue-400 transition-colors truncate">
                                <%= episode.title %>
                            </h4>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% }) %>

        <% if (anime.specialInfo && anime.specialInfo.trim() !== '') { %>
        <div class="admin-info-banner animate-pulse-subtle">
            <h3><i class="fas fa-bullhorn mr-2"></i> Anime Updates </h3>
            <p><%= anime.specialInfo %></p>
        </div>
    <% } %>
    </div>

<div class="support-share-card">
    <h2>Thanks for Watching!</h2>
    <p>We hope you enjoyed the episode. Please support our community by sharing <strong><%= anime.name %></strong> with your friends and family!</p>

    <% 
        // Dynamic URL construction
        const animeUrl = `https://anifusionstream.com/anime/${anime._id}`; 
        const shareText = `Check out ${anime.name} on AniFusionStream!`;
    %>

    <div class="share-grid">
        <a href="https://api.whatsapp.com/send?text=<%= encodeURIComponent(shareText + ' ' + animeUrl) %>" 
           target="_blank" class="share-btn btn-wa" title="Share on WhatsApp">
            <i class="fab fa-whatsapp"></i>
        </a>

        <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(animeUrl) %>" 
           target="_blank" class="share-btn btn-fb" title="Share on Facebook">
            <i class="fab fa-facebook-f"></i>
        </a>

        <a href="https://twitter.com/intent/tweet?text=<%= encodeURIComponent(shareText) %>&url=<%= encodeURIComponent(animeUrl) %>" 
           target="_blank" class="share-btn btn-x" title="Share on X">
            <i class="fab fa-x-twitter"></i>
        </a>

        <a href="https://t.me/share/url?url=<%= encodeURIComponent(animeUrl) %>&text=<%= encodeURIComponent(shareText) %>" 
           target="_blank" class="share-btn btn-tg" title="Share on Telegram">
            <i class="fab fa-telegram-plane"></i>
        </a>

        <button onclick="copyAnimeLink('<%= animeUrl %>')" class="share-btn btn-copy" title="Copy Link to Clipboard">
            <i class="fas fa-link"></i>
        </button>
    </div>
</div>

<script>
function copyAnimeLink(url) {
    navigator.clipboard.writeText(url).then(() => {
        alert("Anime link copied! You can now share it on Discord or Instagram.");
    });
}
</script>

    <div class="mt-20 glass-card p-6 md:p-10">
        <h2 class="text-3xl font-black uppercase tracking-tighter mb-8">Community <span class="text-blue-500">Voice</span></h2>
        
        <% if (session.user || session.isAdminAuthenticated) { %>
            <form action="/anime/comment/<%= anime._id %>" method="POST" class="mb-10">
                <div class="relative">
                    <textarea name="content" rows="3" class="w-full p-5 rounded-2xl bg-black/30 border border-white/5 text-white focus:outline-none focus:border-blue-500 transition-all placeholder-gray-600 font-medium" placeholder="Join the discussion..."></textarea>
                    <button type="submit" class="absolute bottom-4 right-4 bg-blue-600 text-white px-6 py-1.5 rounded-lg font-bold uppercase text-xs tracking-widest hover:bg-blue-500">Post</button>
                </div>
            </form>
        <% } %>

        <div class="space-y-6">
            <% function renderComments(comments, depth = 0) { %>
                <% comments.forEach(function(comment) { %>
                    <div class="bg-white/5 p-5 rounded-2xl border border-white/5 <%= depth > 0 ? 'ml-8 mt-4 border-l-2 border-blue-500/30' : '' %>">
                        <div class="flex justify-between items-center mb-3">
                            <div class="flex items-center gap-2">
                                <span class="font-black text-blue-400 text-xs uppercase tracking-wider"><%= comment.username %></span>
                            </div>
                            
                            <div class="flex items-center gap-4">
                                <span class="text-[10px] text-gray-500 font-bold uppercase"><%= new Date(comment.createdAt).toLocaleDateString('en-IN') %></span>
                                
                                <% if (session.isAdminAuthenticated || (session.user && comment.user && session.user._id.toString() === comment.user._id.toString())) { %>
                                    <form action="/anime/comment/delete/<%= anime._id %>/<%= comment._id %>" method="POST" onsubmit="return confirm('Delete this comment?');">
                                        <button type="submit" class="text-red-500/40 hover:text-red-500 transition-colors">
                                            <i class="fas fa-trash-alt text-xs"></i>
                                        </button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                        <p class="text-sm text-gray-300 leading-relaxed"><%= comment.content %></p>
                    </div>
                <% }); %>
            <% } %>

            <% if (comments && comments.length > 0) { renderComments(comments); } else { %>
                <p class="text-center py-10 text-gray-600 font-bold uppercase tracking-widest text-xs">No Conversation yet. Start the conversation.</p>
            <% } %>
        </div>
    </div>

    <div class="mt-12">
        <h2 class="text-2xl font-bold mb-4 text-blue-400">Random Anime</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-4 lg:grid-cols-4 gap-6">
            <% (randomAnimes || []).forEach(function(anime) { %>
                <div class="anime-card flex flex-col items-center bg-gray-800 rounded-lg shadow-lg p-2 hover:shadow-2xl transition-shadow duration-300">
                    <a href="/anime/<%= anime._id %>" class="relative w-full">
                        <img src="<%= anime.imageUrl %>" alt="<%= anime.name %>" class="w-full h-48 object-cover rounded-md transition-transform duration-200 hover:scale-105 shadow-md">
                    </a>
                    <p class="text-center mt-2 text-white font-semibold hover:text-blue-300 transition-colors duration-200 truncate w-full text-base"><%= anime.name %></p>
                </div>
            <% }); %>
        </div>
    </div>

</div>

<script>
    const seasonSelect = document.getElementById('season-select');
    const seasonSections = document.querySelectorAll('.season-section');
    const videoArea = document.getElementById('video-area');
    const playerContainer = document.getElementById('player-container');
    const videoTitleDisplay = document.getElementById('active-video-title');
    const episodeCards = document.querySelectorAll('.episode-card');

    seasonSelect.addEventListener('change', (e) => {
        const selected = e.target.value;
        seasonSections.forEach(s => s.dataset.season === selected ? s.classList.remove('hidden') : s.classList.add('hidden'));
        videoArea.classList.add('hidden'); 
    });

    episodeCards.forEach(card => {
        card.addEventListener('click', () => {
            const videoUrl = card.dataset.videoUrl;
            const embedCode = card.dataset.embedCode;
            const title = card.dataset.title;

            playerContainer.innerHTML = '';

            if (embedCode && embedCode.trim() !== '') {
                playerContainer.innerHTML = embedCode;
                const iframe = playerContainer.querySelector('iframe');
                if (iframe) iframe.className = "absolute inset-0 w-full h-full border-0";
            } else {
                playerContainer.innerHTML = `
                    <video id="active-player" class="absolute inset-0 w-full h-full" controls autoplay poster="<%= anime.imageUrl %>">
                        <source src="${videoUrl}" type="video/mp4">
                        Your browser does not support the video tag.
                    </video>`;
            }

            videoTitleDisplay.textContent = title;
            videoArea.classList.remove('hidden');
            videoArea.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
    });
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<%- include('partials/footer') %>