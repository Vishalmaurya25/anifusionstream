<%- include('partials/header') %>

<style>
    :root {
        --bg-deep: #0b0e11;
        --card-navy: #151b23;
        --accent-blue: #3b82f6;
        --accent-yellow: #facc15;
        --glass-border: rgba(255, 255, 255, 0.05);
    }

    body { 
        background-color: var(--bg-deep); 
        font-family: 'Inter', sans-serif;
        color: #f3f4f6;
    }

    /* Glass Effect Hero Card */
    .glass-card {
        background: rgba(21, 27, 35, 0.6);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--glass-border);
        border-radius: 1.5rem;
    }

    /* Strict 3-Column Episode Card */
    .episode-card {
        background: var(--card-navy);
        border: 1px solid var(--glass-border);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border-radius: 1rem;
        overflow: hidden;
    }

    .episode-card:hover {
        transform: translateY(-5px);
        border-color: var(--accent-blue);
        box-shadow: 0 15px 30px -10px rgba(59, 130, 246, 0.4);
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(236, 72, 153, 0.1) 100%);
    }

    .player-shadow {
        box-shadow: 0 0 80px -20px rgba(59, 130, 246, 0.2);
    }

    /* Custom scrollbar for better elegance */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: var(--bg-deep); }
    ::-webkit-scrollbar-thumb { background: #374151; border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--accent-blue); }
</style>

<div class="container mx-auto px-4 py-8 max-w-6xl">

    <div class="glass-card mb-10 p-6 md:p-8 flex flex-col md:flex-row gap-8 items-center">
        <div class="relative group">
            <img src="<%= anime.imageUrl %>" alt="<%= anime.name %>" 
                 class="w-full md:w-64 rounded-xl shadow-2xl object-cover transition-transform duration-500 hover:scale-105">
            <div class="absolute inset-0 rounded-xl ring-1 ring-inset ring-white/10"></div>
        </div>

        <div class="flex-1 space-y-4">
            <h1 class="text-3xl md:text-5xl font-black tracking-tighter uppercase leading-tight">
                <% const nameParts = anime.name.split(' '); %>
                <span class="text-white"><%= nameParts[0] %></span>
                <span class="text-yellow-400"><%= nameParts.slice(1).join(' ') %></span>
            </h1>

            <div class="flex flex-wrap gap-3 text-[10px] font-bold uppercase tracking-widest text-gray-400">
                <span class="bg-white/5 px-3 py-1.5 rounded-full border border-white/5">📅 <%= anime.year || '2024' %></span>
                <span class="bg-white/5 px-3 py-1.5 rounded-full border border-white/5">🕒 <%= anime.duration || '24m' %></span>
                <span class="bg-blue-500/10 text-blue-400 px-3 py-1.5 rounded-full border border-blue-500/20">HD Dual Audio</span>
            </div>

            <p class="text-gray-300 leading-relaxed font-medium text-base md:text-lg border-l-2 border-blue-500 pl-4">
                <%= anime.description %>
            </p>

            <div class="pt-2">
                <h3 class="text-xs font-black uppercase tracking-widest text-gray-500 mb-3">Genre Classification</h3>
                <div class="flex flex-wrap gap-2">
                    <% anime.genres.forEach(genre => { %>
                        <span class="px-4 py-1.5 rounded-lg text-[11px] font-black uppercase tracking-widest bg-gray-800 border border-white/5 hover:border-blue-500 transition-all cursor-default">
                            <%= genre.name %>
                        </span>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>

    <div id="video-area" class="mb-12 hidden">
        <div class="glass-card p-2 player-shadow overflow-hidden">
            <div id="player-container" class="relative w-full aspect-video bg-black rounded-lg overflow-hidden">
                </div>
        </div>
        <div class="mt-4 flex justify-between items-center">
            <h2 id="active-video-title" class="text-xl font-black text-white uppercase tracking-tight"></h2>
            <button onclick="document.getElementById('video-area').classList.add('hidden')" class="text-xs font-bold text-gray-500 hover:text-white uppercase tracking-widest">Close Player ×</button>
        </div>
    </div>

    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <h2 class="text-2xl font-black uppercase tracking-tighter flex items-center gap-3">
            <div class="w-1.5 h-6 bg-blue-500 rounded-full"></div>
            Episode <span class="text-gray-500">Library</span>
        </h2>
        
        <div class="relative">
            <select id="season-select" class="appearance-none bg-gray-800 border border-white/10 text-white px-6 py-2 rounded-xl font-bold text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 min-w-[160px]">
                <% anime.seasons.forEach((season, index) => { %>
                    <option value="<%= index %>">Season <%= season.seasonNumber %></option>
                <% }) %>
            </select>
            <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-blue-500">
                ▼
            </div>
        </div>
    </div>

    <div id="episodes-container">
        <% anime.seasons.forEach((season, seasonIndex) => { %>
            <div class="season-section grid grid-cols-3 gap-4 md:gap-6 <%= seasonIndex === 0 ? '' : 'hidden' %>" data-season="<%= seasonIndex %>">
                <% season.episodes.forEach(episode => { %>
                    <div class="episode-card p-2 cursor-pointer group"
                         data-video-url="<%= episode.videoUrl %>"
                         data-embed-code="<%= episode.embedCode || '' %>"
                         data-title="Ep <%= episode.episodeNumber %>: <%= episode.title %>">
                        <div class="relative aspect-video rounded-lg overflow-hidden mb-3">
                            <img src="<%= anime.imageUrl %>" class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity">
                            <div class="absolute inset-0 flex items-center justify-center bg-black/40 group-hover:bg-transparent transition-all">
                                <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center shadow-xl transform scale-0 group-hover:scale-100 transition-transform">
                                    <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M5 3l10 7-10 7V3z"/></svg>
                                </div>
                            </div>
                            <div class="absolute bottom-1.5 left-1.5 bg-black/80 px-2 py-0.5 rounded text-[9px] font-black uppercase border border-white/10">
                                EP <%= episode.episodeNumber %>
                            </div>
                        </div>
                        <h4 class="font-bold text-[11px] md:text-sm text-gray-200 group-hover:text-blue-400 transition-colors truncate">
                            <%= episode.title %>
                        </h4>
                    </div>
                <% }) %>
            </div>
        <% }) %>
    </div>

    <div class="mt-20 glass-card p-6 md:p-10">
        <h2 class="text-3xl font-black uppercase tracking-tighter mb-8">Community <span class="text-blue-500">Voice</span></h2>
        
        <% if (session.user || session.isAdminAuthenticated) { %>
            <form action="/anime/comment/<%= anime._id %>" method="POST" class="mb-10">
                <div class="relative">
                    <textarea name="content" rows="3" class="w-full p-5 rounded-2xl bg-black/30 border border-white/5 text-white focus:outline-none focus:border-blue-500 transition-all placeholder-gray-600 font-medium" placeholder="Join the discussion..."></textarea>
                    <button type="submit" class="absolute bottom-4 right-4 bg-blue-600 text-white px-6 py-1.5 rounded-lg font-bold uppercase text-xs tracking-widest hover:bg-blue-500 transition-colors">Post</button>
                </div>
            </form>
        <% } %>

        <div class="space-y-6">
            <% function renderComments(comments, depth = 0) { %>
                <% comments.forEach(function(comment) { %>
                    <div class="bg-white/5 p-5 rounded-2xl border border-white/5 <%= depth > 0 ? 'ml-8 mt-4 border-l-2 border-blue-500/30' : '' %>">
                        <div class="flex justify-between items-center mb-3">
                            <div class="flex items-center gap-2">
                                <span class="font-black text-blue-400 text-xs uppercase tracking-wider"><%= comment.username %></span>
                                <% if (session.isAdminAuthenticated) { %><span class="text-[10px] text-gray-500 italic"><%= comment.email %></span><% } %>
                            </div>
                            <span class="text-[10px] text-gray-500 font-bold uppercase"><%= new Date(comment.createdAt).toLocaleDateString('en-IN') %></span>
                        </div>
                        <p class="text-sm text-gray-300 leading-relaxed"><%= comment.content %></p>
                        
                        <% if (session.user || session.isAdminAuthenticated) { %>
                            <button onclick="this.nextElementSibling.classList.toggle('hidden')" class="mt-3 text-[10px] font-black uppercase text-blue-500/60 hover:text-blue-500 tracking-widest">Reply</button>
                            <form action="/anime/comment/reply/<%= anime._id %>/<%= comment._id %>" method="POST" class="mt-3 hidden">
                                <div class="flex gap-2">
                                    <input name="content" class="flex-1 bg-black/40 border border-white/5 rounded-lg px-4 py-1 text-sm text-white" placeholder="Write a reply...">
                                    <button class="bg-blue-600 px-4 py-1 rounded-lg text-xs font-bold uppercase">Send</button>
                                </div>
                            </form>
                        <% } %>
                        
                        <% if (comment.replies && comment.replies.length > 0) { %>
                            <% renderComments(comment.replies, depth + 1); %>
                        <% } %>
                    </div>
                <% }); %>
            <% } %>

            <% if (comments && comments.length > 0) { renderComments(comments); } else { %>
                <p class="text-center py-10 text-gray-600 font-bold uppercase tracking-widest text-xs">No transmissions yet. Start the conversation.</p>
            <% } %>
        </div>
    </div>

    <div class="mt-12">
        <h2 class="text-2xl font-bold mb-4 text-blue-400">Random Anime</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-4 lg:grid-cols-4 gap-6">
            <% (randomAnimes || []).forEach(function(anime) { %>
                <div class="anime-card flex flex-col items-center bg-gray-800 rounded-lg shadow-lg p-2 hover:shadow-2xl transition-shadow duration-300">
                    <a href="/anime/<%= anime._id %>" class="relative w-full">
                        <img src="<%= anime.imageUrl %>" alt="<%= anime.name %>" class="w-full h-48 object-cover rounded-md transition-transform duration-200 hover:scale-105 shadow-md">
                    </a>
                    <p class="text-center mt-2 text-white font-semibold hover:text-blue-300 transition-colors duration-200 truncate w-full text-base"><%= anime.name %></p>
                </div>
            <% }); %>
        </div>
    </div>

</div>

<script>
    const seasonSelect = document.getElementById('season-select');
    const seasonSections = document.querySelectorAll('.season-section');
    const videoArea = document.getElementById('video-area');
    const playerContainer = document.getElementById('player-container');
    const videoTitleDisplay = document.getElementById('active-video-title');
    const episodeCards = document.querySelectorAll('.episode-card');

    // Season Switching
    seasonSelect.addEventListener('change', (e) => {
        const selected = e.target.value;
        seasonSections.forEach(s => s.dataset.season === selected ? s.classList.remove('hidden') : s.classList.add('hidden'));
        videoArea.classList.add('hidden'); 
    });

    // Unified Player Logic
    episodeCards.forEach(card => {
        card.addEventListener('click', () => {
            const videoUrl = card.dataset.videoUrl;
            const embedCode = card.dataset.embedCode;
            const title = card.dataset.title;

            playerContainer.innerHTML = '';

            if (embedCode && embedCode.trim() !== '') {
                playerContainer.innerHTML = embedCode;
                const iframe = playerContainer.querySelector('iframe');
                if (iframe) iframe.className = "absolute inset-0 w-full h-full border-0";
            } else {
                playerContainer.innerHTML = `
                    <video id="active-player" class="absolute inset-0 w-full h-full" controls autoplay poster="<%= anime.imageUrl %>">
                        <source src="${videoUrl}" type="video/mp4">
                        Your browser does not support the video tag.
                    </video>`;
            }

            videoTitleDisplay.textContent = title;
            videoArea.classList.remove('hidden');
            videoArea.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
    });
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<%- include('partials/footer') %>