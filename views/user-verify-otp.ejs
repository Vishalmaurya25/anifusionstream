<%- include('partials/header') %>

<style>
    :root {
        --bg-deep: #0b0e11;
        --card-navy: #151b23;
        --input-dark: #1c232d;
        --primary-blue: #3b82f6;
        --text-muted: #9ca3af;
    }

    body { 
        background-color: var(--bg-deep); 
        color: #ffffff; 
        font-family: 'Inter', sans-serif; 
    }

    .auth-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 85vh;
        padding: 3rem 1.25rem;
    }

    .ui-card {
        background-color: var(--card-navy);
        border: 1px solid rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(20px);
        border-radius: 2.5rem;
        width: 100%;
        max-width: 450px;
        padding: 4rem 2.5rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
        text-align: center;
    }

    .ui-label {
        font-size: 0.75rem;
        font-weight: 800;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.8rem;
        display: block;
        text-align: left;
    }

    .ui-input {
        background-color: var(--input-dark);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 1rem;
        color: #ffffff;
        padding: 1.2rem;
        width: 100%;
        transition: all 0.3s ease;
        font-size: 1.5rem; /* Larger font for OTP digits */
        font-weight: 800;
        text-align: center;
        letter-spacing: 0.5em;
    }

    .ui-input::placeholder {
        letter-spacing: normal;
        font-size: 1rem;
        color: rgba(255, 255, 255, 0.1);
    }

    .ui-input:focus {
        outline: none;
        border-color: var(--primary-blue);
        box-shadow: 0 0 0 1px var(--primary-blue);
        background-color: #232a33;
    }

    .ui-button {
        background-color: var(--primary-blue);
        color: #ffffff;
        font-weight: 800;
        padding: 1.1rem;
        border-radius: 1rem;
        width: 100%;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border: none;
        margin-top: 1.5rem;
        cursor: pointer;
    }

    .ui-button:hover {
        transform: translateY(-2px);
        filter: brightness(1.1);
        box-shadow: 0 10px 25px rgba(59, 130, 246, 0.3);
    }

    .back-link {
        color: var(--text-muted);
        font-size: 0.85rem;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 2rem;
    }

    .back-link:hover { color: #fff; }

    .resend-text {
        margin-top: 1.5rem;
        font-size: 0.85rem;
        color: var(--text-muted);
        font-weight: 600;
    }

    .resend-text a {
        color: var(--primary-blue);
        font-weight: 800;
        text-decoration: none;
    }
</style>

<div class="auth-wrapper">
    <div class="text-center mb-10">
        <div class="flex justify-center mb-4">
            <div class="p-4 bg-blue-500/10 rounded-full border border-blue-500/20">
                <svg class="w-8 h-8 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
        </div>
        <h1 class="text-4xl font-black tracking-tighter uppercase">
            Verify <span class="text-blue-500">Identity</span>
        </h1>
        <p class="text-gray-500 mt-2 font-medium">We've sent a code to your inbox</p>
    </div>

    <div class="ui-card">
        <a href="/user/forgot-password" class="back-link">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Change Email
        </a>

        <% if (typeof messages !== 'undefined' && messages.length > 0) { %>
            <div class="bg-red-500/10 border border-red-500/20 text-red-400 p-4 rounded-xl mb-8 text-xs font-bold text-center uppercase tracking-widest">
                <%= messages %>
            </div>
        <% } %>

        <form action="/user/verify-otp" method="POST">
            <div class="mb-4">
                <label class="ui-label">6-Digit Verification Code</label>
                <input type="text" 
                       name="otp" 
                       maxlength="6" 
                       pattern="\d{6}" 
                       class="ui-input" 
                       placeholder="000000" 
                       required 
                       autocomplete="one-time-code">
            </div>

            <button type="submit" class="ui-button">
                Verify Account
            </button>

            <p class="resend-text">
                Didn't receive the code? <br class="md:hidden">
                <a href="/user/resend-otp" class="hover:underline">Resend OTP</a>
            </p>
        </form>
    </div>
</div>

<%- include('partials/footer') %>